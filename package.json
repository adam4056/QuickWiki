{
  "name": "thequickwiki",
  "version": "1.0.0",
  "description": "Lightning-fast 25-word AI definitions for podcasters & editors. Powered by Wikipedia + AI.",
  "license": "MIT",
  "author": "Adam Skřivánek",
  "keywords": [
    "wikipedia",
    "ai",
    "definitions",
    "summarizer",
    "openrouter"
  ],
  "type": "commonjs",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./public/output.css",
    "build:css:watch": "tailwindcss -i ./src/input.css -o ./public/output.css --watch",
    "build:css:minify": "tailwindcss -i ./src/input.css -o ./public/output.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "lucide": "^0.536.0",
    "tailwindcss": "^4.1.11"
  }
}
